# ─────────────────────────────────────────────────────────────────
# Almaty 3D Map — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Mapbox GL JS token (REQUIRED)
# Used for: map tiles, 3D buildings, terrain, dark basemap
# Get a free token at: https://mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# WAQI (World Air Quality Index) token (OPTIONAL)
# Used for: real-time air quality station data around Almaty
# Free token at: https://aqicn.org/api/
# Without this key the app uses the 'demo' token (limited to demo stations)
VITE_WAQI_TOKEN=your_waqi_token_here

# TomTom Traffic API key (OPTIONAL)
# Used for: real-time traffic flow tile overlay and incident markers
# Free tier: 2,500 req/day — sign up at https://developer.tomtom.com
# Without this key traffic layers will be hidden
VITE_TOMTOM_KEY=your_tomtom_key_here
